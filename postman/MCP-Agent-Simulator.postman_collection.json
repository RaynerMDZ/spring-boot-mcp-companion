{
  "info": {
    "name": "Spring Boot MCP - AI Agent Simulator",
    "description": "Postman collection to simulate AI agent interactions with Model Context Protocol. Uses single /mcp endpoint with JSON-RPC 2.0 protocol per official MCP specification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "mcpEndpoint",
      "value": "/mcp",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "agentName",
      "value": "Claude-AI-Agent",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Server Information",
      "item": [
        {
          "name": "Initialize - server/info",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "{{agentName}}/1.0"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"init-1\",\n  \"method\": \"server/info\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpEndpoint}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpEndpoint}}"
              ]
            },
            "description": "Get server metadata and capabilities (JSON-RPC method: server/info)"
          },
          "response": []
        }
      ]
    },
