          "name": "Call Tool - With Validation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-request-126\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"create_user\",\n    \"arguments\": {\n      \"email\": \"user@example.com\",\n      \"password\": \"SecurePass123!\",\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"age\": 30\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/tools/call",
              "host": [
                "{{baseUrl}}"
