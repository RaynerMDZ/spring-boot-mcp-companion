    {
      "name": "AI Agent Workflows",
      "item": [
        {
          "name": "1. Initialize - Get Server Capabilities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "{{agentName}}/1.0"
              },
              {
                "key": "X-Agent-ID",
                "value": "agent-{{requestId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/server-info",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "server-info"
              ]
            },
            "description": "Step 1: AI Agent initializes and checks server capabilities"
          },
          "response": []
        },
        {
          "name": "2. Discover - List Available Tools",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-discovery-tools\",\n  \"method\": \"tools/list\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/tools/list",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "tools",
                "list"
              ]
            },
            "description": "Step 2: AI Agent discovers what tools are available"
          },
          "response": []
        },
        {
          "name": "3. Discover - List Available Resources",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-discovery-resources\",\n  \"method\": \"resources/list\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/resources/list",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "resources",
                "list"
              ]
            },
            "description": "Step 3: AI Agent discovers available resources"
          },
          "response": []
        },
        {
          "name": "4. Discover - List Available Prompts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-discovery-prompts\",\n  \"method\": \"prompts/list\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/prompts/list",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "prompts",
                "list"
              ]
            },
            "description": "Step 4: AI Agent discovers available prompts"
          },
          "response": []
        },
        {
          "name": "5. Execute - Call a Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Agent-Decision",
                "value": "tool_selected"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-execution-1\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"analyze_code\",\n    \"arguments\": {\n      \"code\": \"public class Example { public static void main(String[] args) { System.out.println(\\\"Hello\\\"); } }\",\n      \"language\": \"java\",\n      \"checkSecurityIssues\": true\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/tools/call",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "tools",
                "call"
              ]
            },
            "description": "Step 5: AI Agent decides to call a tool and executes it"
          },
          "response": []
        },
        {
          "name": "6. Context - Read Required Resource",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Agent-Decision",
                "value": "resource_read\"",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-context-1\",\n  \"method\": \"resources/read\",\n  \"params\": {\n    \"uri\": \"project://config/build.properties\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/resources/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "resources",
                "read"
              ]
            },
            "description": "Step 6: AI Agent reads a resource to get context"
          },
          "response": []
        },
        {
          "name": "7. Reasoning - Get Prompt Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Agent-Reasoning",
                "value": "use_prompt_template\""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-reasoning-1\",\n  \"method\": \"prompts/get\",\n  \"params\": {\n    \"name\": \"problem_solving\",\n    \"arguments\": {\n      \"problem\": \"High latency in API responses\",\n      \"context\": \"Production environment\",\n      \"constraints\": [\"Cannot modify database schema\", \"Limited infrastructure changes\"]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/prompts/get",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "prompts",
                "get"
              ]
            },
            "description": "Step 7: AI Agent gets a prompt to help with reasoning"
          },
          "response": []
        }
      ]
    },
