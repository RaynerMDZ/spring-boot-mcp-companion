            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"agent-request-125\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"process_order\",\n    \"arguments\": {\n      \"order\": {\n        \"id\": \"ORD-12345\",\n        \"customerId\": \"CUST-789\",\n        \"amount\": 299.99,\n        \"items\": [\n          {\n            \"sku\": \"ITEM-001\",\n            \"quantity\": 2,\n            \"price\": 50.00\n          },\n          {\n            \"sku\": \"ITEM-002\",\n            \"quantity\": 1,\n            \"price\": 199.99\n          }\n        ],\n        \"status\": \"pending\",\n        \"metadata\": {\n          \"source\": \"ai-agent\",\n          \"timestamp\": \"2024-03-28T10:30:00Z\"\n        }\n      }\n    }\n  }\n}"
