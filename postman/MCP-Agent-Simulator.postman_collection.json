{
  "info": {
    "name": "Spring Boot MCP - AI Agent Simulator",
    "description": "Postman collection to simulate AI agent interactions with Model Context Protocol endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "mcpBasePath",
      "value": "/mcp",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "agentName",
      "value": "Claude-AI-Agent",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Server Information",
      "item": [
        {
          "name": "Get Server Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "{{agentName}}/1.0"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}{{mcpBasePath}}/server-info",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{mcpBasePath}}",
                "server-info"
              ]
            },
            "description": "Retrieve server metadata and capabilities"
          },
          "response": []
        }
      ]
    },
    {
